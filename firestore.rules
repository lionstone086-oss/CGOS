rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection Test Path
    match /test/connection {
      allow read: if true;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Demands Collection
    match /demands/{demandId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && 
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.title is string &&
        request.resource.data.status == 'active';
      allow update: if isSignedIn() && (
        // Only allow voting (legacy increment, preferred via subcollection)
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votesCount']) ||
        // Owner can edit details if still active
        (isOwner(resource.data.authorId) && resource.data.status == 'active')
      );

      // Votes Subcollection
      match /votes/{voteId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
          request.resource.data.userId == request.auth.uid &&
          !exists(/databases/$(database)/documents/demands/$(demandId)/votes/$(request.auth.uid));
      }
    }

    // Discussions Collection
    match /discussions/{discussionId} {
      allow read: if isSignedIn();
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
          request.resource.data.authorId == request.auth.uid &&
          request.resource.data.content is string &&
          request.resource.data.content.size() <= 1000;
      }
    }

    // Reports Collection
    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        request.resource.data.authorId == request.auth.uid;
      allow delete: if isOwner(resource.data.authorId);
    }
    
    // Budgets Collection (Read-only for users)
    match /budgets/{budgetId} {
      allow read: if isSignedIn();
    }

    // Contracts Collection
    match /contracts/{contractId} {
      allow read: if isSignedIn();
    }

    // Projects Collection
    match /projects/{projectId} {
      allow read: if isSignedIn();
    }
  }
}
